                        "top": "0px"
                    }
                }
            }
        },
        "color": {
            "text": "var(--wp--preset--color--white)",
            "background": "var(--wp--preset--color--black)"
        },
        "elements": {
            "heading": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--michroma)"
                },
                "color": {
                    "text": "var(--wp--preset--color--white)"
                }
            },
            "link": {
                "color": {
                    "text": "var(--wp--preset--color--white)"
                },
                "typography": {
                    "textDecoration": "underline"
                }
            },
            "button": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--michroma)",
                    "fontWeight": "100"
                }
            }
        },
        "typography": {
